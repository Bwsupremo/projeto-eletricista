; Não usamos AudioStreamOpusChunked aqui para evitar erro de parser se twovoip não carregar.
[node name="VoipReceiver" type="AudioStreamPlayer"]
volume_db = 0.0
autoplay = false
bus = &"Radio"
script = ExtResource("1_recv")
