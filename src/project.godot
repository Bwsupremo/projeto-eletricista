; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fio Pelado"
config/description="Jogo cooperativo de eletricista para até 4 jogadores. Baseado em GodotSteam com lobby Steam, VoIP Opus e fluxo Menu → Lobby → Briefing → Gameplay → Resultado."
run/main_scene="res://assets/scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://assets/audio/bus.tres"
driver/enable_input=true

[autoload]

NetworkManager="*res://assets/scripts/globals/network_manager.gd"
GameManager="*res://assets/scripts/globals/game_manager.gd"
Settings="*res://assets/scripts/globals/settings.gd"
VoipManager="*res://assets/scenes/voip/voip_manager.tscn"
AppConfig="*res://addons/maaacks_game_template/base/nodes/autoloads/app_config/app_config.tscn"
SceneLoader="*res://addons/maaacks_game_template/base/nodes/autoloads/scene_loader/scene_loader.tscn"

[display]

window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/maaacks_game_template/plugin.cfg")

